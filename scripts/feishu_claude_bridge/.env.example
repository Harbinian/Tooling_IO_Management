FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxx

# Only the listed users can drive Claude remotely. Leave empty to disable.
ALLOW_OPEN_IDS=

# Optional chat allowlist. Leave empty to allow any chat from allowed users.
ALLOW_CHAT_IDS=

# In group chats, messages must start with this prefix to be picked up.
COMMAND_PREFIX=/cc

# plan: read-only by default, apply: uses the apply tool profile by default.
DEFAULT_EXECUTION_MODE=plan

# Claude CLI settings
CLAUDE_BIN=claude
CLAUDE_WORKDIR=E:\CA001\Tooling_IO_Management
CLAUDE_SETTING_SOURCES=user,project,local
CLAUDE_MODEL=
CLAUDE_TIMEOUT_MS=1800000
CLAUDE_ALLOWED_TOOLS_PLAN=Read,Glob,Grep
CLAUDE_ALLOWED_TOOLS_APPLY=Read,Glob,Grep,Edit,Write
CLAUDE_PERMISSION_MODE=
CLAUDE_APPEND_SYSTEM_PROMPT=Reply in Chinese. Be concise, action-oriented, and explicit about verification limits.

# Runtime storage
SESSION_STORE_PATH=./data/sessions.json

# Feishu reply chunking
FEISHU_REPLY_CHUNK_SIZE=1500
FEISHU_REPLY_MAX_CHARS=12000
