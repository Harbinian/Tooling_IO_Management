{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "types": [
      "vite/client"
    ],
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ]
  },
  "include": [
    "src/api/client.js",
    "src/api/orders.js",
    "src/api/tools.js",
    "src/api/mpl.js",
    "src/api/auth.js",
    "src/api/dashboard.js",
    "src/api/types/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
