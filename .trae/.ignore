# Repo Context Firewall - Ignore Rules
# Generated by repo-context-firewall skill
# Synced with .claudeignore
# Last updated: 2026-04-08

# ============================================================
# GROUP A - Safe to Ignore
# ============================================================

# Dependencies
.venv/
venv/
env/
frontend/node_modules/

# Build outputs
frontend/dist/
build/
dist/
bin/
obj/


# Logs (high token cost)
logs/

# IDE
.vscode/
.idea/

# Environment files
.env

# Temporary files
*.tmp
*.temp
__pycache__/
*.py[cod]
*$py.class

# ============================================================
# GROUP B - Keep but Avoid Frequent Loading
# ============================================================

# Archived prompts (historical records)
promptsRec/archive/

# Old review/design documents
docs/archive/

# Large development context docs
AGENTS.md

# ============================================================
# NEVER IGNORE - Critical Source Files
# ============================================================

# Backend source
!backend/

# Frontend source
!frontend/src/

# Active prompts
!promptsRec/active/

# Skills
!.skills/

# Development rules
!.claude/rules/

# Architecture documents
!docs/PRD.md
!docs/ARCHITECTURE.md
!docs/API_SPEC.md
!docs/DB_SCHEMA.md
!docs/RBAC_DESIGN.md
!docs/RBAC_PERMISSION_MATRIX.md
!docs/archive/PROMPT_TASK_CONVENTION.md

# Current config
!.claude/commands.md
!.claude/settings.local.json

# ============================================================
# NOTES
# ============================================================
# Pattern style: gitignore-compatible
# Prefix ! to negate (un-ignore)
# Earlier rules take precedence
